#!/bin/sh
set -e

# Create the netcap system group if it does not exist.
if ! getent group netcap > /dev/null 2>&1; then
    addgroup --system netcap
fi

# Create the netcap system user if it does not exist.
if ! getent passwd netcap > /dev/null 2>&1; then
    adduser --system \
            --ingroup netcap \
            --no-create-home \
            --home /var/lib/netcap \
            --shell /usr/sbin/nologin \
            --gecos "netcap capture agent" \
            netcap
fi
